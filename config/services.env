# EcomCore Services — Environment Configuration
# Copy to .env and fill in secrets before running

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=postgres.internal
DB_PORT=5432
DB_NAME=ecomcore
DB_USER=ecomcore_app
DB_PASSWORD=
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=5

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_MAX_CONNECTIONS=100

# ─── Service Discovery ───────────────────────────────────────────────────────
PAYMENT_SERVICE_URL=http://payment-service.internal:8002
INVENTORY_SERVICE_URL=http://inventory-service.internal:8003
NOTIFICATION_SERVICE_URL=http://notification-service.internal:8004
FRAUD_SERVICE_URL=http://fraud-service.internal:8005

# ─── External APIs ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=ecomcore
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/ecomcore

# ─── Application ──────────────────────────────────────────────────────────────
WEB_CONCURRENCY=9
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_FRAUD_CHECK=true
ENABLE_INVENTORY_RESERVATION=true
ENABLE_SMS_NOTIFICATIONS=true
